generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//
// =========================
// ENUM
// =========================
//

enum UserRole {
  admin
  customer
}

enum OrderStatus {
  PENDING
  PAID
  PROCESS
  DONE
  CANCEL
}

//
// =========================
// USER
// =========================
//

model User {
  id       Int    @id @default(autoincrement())
  username String
  email    String @unique
  password String

  role UserRole @default(customer)

  orders Order[]

  reservations Reservation[]
}

//
// =========================
// MENU
// =========================
//

model Menu {
  id          Int     @id @default(autoincrement())
  name        String
  price       Int
  description String?
  image       String?

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())

  orderItems OrderItem[]
}

//
// =========================
// ORDER
// =========================
//

model Order {
  id Int @id @default(autoincrement())

  userId Int
  totalPrice Int

  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  orderItems OrderItem[]

  payment Payment?

  reservationId Int?         
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
}
//
// =========================
// ORDER ITEM
// =========================
//

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  menuId  Int

  qty Int

  subtotal Int

  order Order @relation(fields: [orderId], references: [id])

  menu Menu @relation(fields: [menuId], references: [id])
}

model Table {
  id       Int     @id @default(autoincrement())
  number   Int     @unique
  isBooked Boolean @default(false)

  reservations Reservation[]
}

model Reservation {
  id      Int      @id @default(autoincrement())
  userId  Int
  tableId Int
  date    DateTime
  status  String   @default("ACTIVE")

  user  User  @relation(fields: [userId], references: [id])
  table Table @relation(fields: [tableId], references: [id])

  // 🎯 DISINI TEMPATNYA YANG BENAR!
  orders Order[]

  @@index([tableId, date])
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  menus Menu[]
}

model Payment {
  id      Int       @id @default(autoincrement())
  orderId Int       @unique
  method  String    // QRIS / CASH
  amount  Int
  status  String    @default("PENDING")
  paidAt  DateTime?

  order Order @relation(fields: [orderId], references: [id]) // 🟢 Biarkan ini sendirian, jangan ada 'orders Order[]' di bawahnya!
}

